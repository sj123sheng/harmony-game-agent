# 复制本文件为 .env 并填入你的真实配置
# API Key 获取地址：https://console.anthropic.com/

# 必填：API Key（中转站通常也会提供一个等价的 Key）
ANTHROPIC_API_KEY=your_api_key_here

# 可选：中转地址（使用第三方中转/代理时填写，直连官方可留空或删除）
# ANTHROPIC_BASE_URL=https://your-relay-endpoint.com

# 可选：模型名称（中转站支持的模型，未设置则用 SDK 默认）
# ANTHROPIC_MODEL=claude-sonnet-4-5
